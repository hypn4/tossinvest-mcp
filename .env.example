# 토스증권 OpenAPI 콘솔에서 발급받은 자격증명 (.env 로 복사 후 채우세요)
# cp .env.example .env

TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# (선택) base URL — 기본값 사용 시 비워두세요
# TOSS_BASE_URL=https://openapi.tossinvest.com

# (선택) 기본 계좌 accountSeq. 설정하면 계좌/자산/주문 API 요청에 전역 기본값으로 주입됩니다.
#        GET /api/v1/accounts 응답의 accountSeq 값을 사용. 툴 호출 시 개별 override 가능.
# TOSS_DEFAULT_ACCOUNT_SEQ=1

# (선택, 안전) 주문 변경 툴(createOrder/modifyOrder/cancelOrder) 노출 여부.
#   기본 false(읽기 전용). true 로 두면 LLM 이 실주문·실자금을 집행할 수 있으니 주의.
# TOSS_ENABLE_TRADING=false

# (선택) 툴 응답을 OpenAPI 응답 스키마로 검증할지. 기본 true.
#   true: 벤더 응답 드리프트 감지 / false: 스펙과 달라도 데이터 그대로 전달(리질리언스)
# TOSS_VALIDATE_OUTPUT=true

# (선택) 재시도 횟수. 429 는 모든 메서드, 5xx/네트워크 오류는 GET 등 안전 메서드에만 적용.
# TOSS_MAX_RETRIES=3

# (선택) HTTP 요청 타임아웃(초)
# TOSS_REQUEST_TIMEOUT=30

# (선택) 로그 레벨(DEBUG/INFO/WARNING/ERROR). 로그는 stderr 로 출력됩니다.
# TOSS_LOG_LEVEL=INFO
